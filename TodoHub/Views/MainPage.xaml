<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoHub.Views.MainPage"
             Title="ホーム">
	
	<!--更新ボタン-->
	<ContentPage.ToolbarItems>
		<ToolbarItem
			x:Name="ReLoadBtn"
			Text="更新"
			Priority="0"
			Order="Primary"
			Clicked="ReLoadBtn_Clicked" />
	</ContentPage.ToolbarItems>
	
    <ScrollView>
        <VerticalStackLayout
            Padding="20,10,20,0"
            Spacing="25">


            <Label
                x:Name="MainMessage"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text=""
                IsVisible="False"/>

            <VerticalStackLayout
                x:Name="TodoList" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
